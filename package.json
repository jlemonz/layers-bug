{
  "name": "layers-bug",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "layers/*"
  ],
  "scripts": {
    "dev": "bun --filter @layers-bug/web dev",
    "dev:admin": "bun --filter @layers-bug/admin dev",
    "dev:all": "bun --filter './apps/*' dev",
    "build": "bun --filter './apps/*' build",
    "build:web": "bun --filter @layers-bug/web build",
    "build:admin": "bun --filter @layers-bug/admin build"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.0"
}
